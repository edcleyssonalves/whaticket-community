# =====================================================================
# Exemplo de configuração de PRODUÇÃO.
# Copie para `.env` na raiz e preencha. NÃO versione o `.env` real.
#   cp .env.production.example .env
# Use com: docker compose -f docker-compose.prod.yaml up -d --build
# =====================================================================

# ----- Domínios -----------------------------------------------------
# Aponte os dois subdomínios (DNS A/AAAA) para o IP do servidor.
FRONTEND_SERVER_NAME=app.seudominio.com
BACKEND_SERVER_NAME=api.seudominio.com

# URLs públicas (com https). FRONTEND_URL é a origem usada no CORS.
FRONTEND_URL=https://app.seudominio.com
BACKEND_URL=https://api.seudominio.com

# Porta usada para montar URLs de mídia: ${BACKEND_URL}:${PROXY_PORT}/public/...
# Em produção HTTPS use 443.
PROXY_PORT=443

# ----- Segredos (OBRIGATÓRIOS) --------------------------------------
# Gere cada um com: openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=

# ----- Banco de dados ----------------------------------------------
MYSQL_DATABASE=whaticket
# Senha do root do MySQL (forte). O backend NÃO usa root.
MYSQL_ROOT_PASSWORD=
# Usuário dedicado que o backend usa (criado automaticamente no 1º boot).
DB_USER=whaticket
DB_PASS=
DB_DIALECT=mysql

# Opcional: fixar engine/versão do banco
# MYSQL_ENGINE=mariadb
# MYSQL_VERSION=10.6

# ----- Diversos -----------------------------------------------------
TZ=America/Fortaleza
WHATSAPP_PROVIDER=wwebjs
# SENTRY_DSN=
